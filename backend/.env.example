# Secret key for JWT signing (generate any random string)
SECRET_KEY=change-this-to-a-random-secret-string

# Optional: If set, AI Search will use Anthropic Claude to generate answers
# grounded in the retrieved knowledge base articles. If left empty, the app
# falls back to an extractive answer (still fully functional, no bugs).
ANTHROPIC_API_KEY=

# CORS: comma separated list of allowed frontend origins
FRONTEND_ORIGIN=http://localhost:5173
